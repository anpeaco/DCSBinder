// DCSBinder UI — GitHub-Light theme.
//
// Layout:
//   - Top: status bar (scan summary, DCS-running banner, Rescan / Undo).
//   - Installs panel: discovered DCS roots.
//   - Left: filterable list of actionable items (conflicts + orphans).
//   - Right: GitHub-style diff with two line-number gutters, hunk headers,
//     and a combined scrollbar + change minimap on the far right.
//
// All colors come from GhTheme.t — change values there to retheme the whole UI.

import { VerticalBox, HorizontalBox, GroupBox, Button, ListView, ScrollView, LineEdit,
         StandardListView, TextEdit, StandardButton, Palette } from "std-widgets.slint";

// ---------------------------------------------------------------- structs ----

struct InstallInfo {
    label: string,
    input-root: string,
    aircraft-count: int,
    device-count: int,
}

struct ConflictRow {
    aircraft: string,
    device-name: string,
    subtype: string,
    candidate-a-guid: string,
    candidate-a-live: bool,
    candidate-b-guid: string,
    candidate-b-live: bool,
    extra-candidates: int,
    is-orphan: bool,
    orphan-target-guid: string,
}

struct DiffSegment {
    text: string,
    // 0 = context, 1 = added, 2 = removed, 3 = hunk header.
    kind: int,
    line-a: int,
    line-b: int,
}

struct SbsRow {
    left-text: string,
    right-text: string,
    left-kind: int,
    right-kind: int,
    line-a: int,
    line-b: int,
    header-kind: int,
    header-text: string,
}

struct AircraftDevice {
    device-name: string,
    guid: string,
    is-live: bool,
    has-conflict: bool,
}

struct AffectedAircraft {
    name: string,
    is-selected: bool,
}

struct PlanSummary {
    device-name: string,
    from-guid: string,
    to-guid: string,
    aircraft-count: int,
    mutation-count: int,
    backup-dir: string,
    lines: [string],
}

// ---------------------------------------------------------------- theme ----

export struct ThemeColors {
    bg: color,
    surface: color,
    surface-2: color,
    border: color,
    border-muted: color,
    text: color,
    text-muted: color,
    accent: color,
    accent-soft: color,
    on-accent: color,
    diff-add-bg: color,
    diff-add-bg-soft: color,
    diff-add-gutter: color,
    diff-add-symbol: color,
    diff-del-bg: color,
    diff-del-bg-soft: color,
    diff-del-gutter: color,
    diff-del-symbol: color,
    diff-hunk-bg: color,
    diff-hunk-text: color,
    diff-line-num: color,
    diff-code: color,
    success: color,
    warning: color,
    warning-soft: color,
    danger: color,
    danger-soft: color,
    danger-text: color,
}

export global GhTheme {
    out property <ThemeColors> t: {
        bg: #ffffff,
        surface: #f6f8fa,
        surface-2: #eaeef2,
        border: #d0d7de,
        border-muted: #d8dee4,
        text: #1f2328,
        text-muted: #57606a,
        accent: #0969da,
        accent-soft: #ddf4ff,
        on-accent: #ffffff,
        diff-add-bg: #dafbe1,
        diff-add-bg-soft: #e6ffec,
        diff-add-gutter: #ccffd8,
        diff-add-symbol: #1a7f37,
        diff-del-bg: #ffebe9,
        diff-del-bg-soft: #ffeef0,
        diff-del-gutter: #ffdce0,
        diff-del-symbol: #cf222e,
        diff-hunk-bg: #ddf4ff,
        diff-hunk-text: #57606a,
        diff-line-num: #57606a,
        diff-code: #1f2328,
        success: #1a7f37,
        warning: #9a6700,
        warning-soft: #fff8c5,
        danger: #cf222e,
        danger-soft: #ffebe9,
        danger-text: #82071e,
    };
}

// --------------------------------------------------------------- AppState ----

export global AppState {
    in property <[InstallInfo]> installs;
    in property <[ConflictRow]> conflicts;
    in property <string> status-text;
    in property <bool> scanning;
    in property <bool> dcs-running;
    in property <int> dcs-running-pid;

    in property <int> selected-index: -1;
    in property <string> selected-source-content;
    in property <string> selected-target-content;
    in property <[DiffSegment]> diff-segments;
    in property <[SbsRow]> sbs-rows;
    in-out property <int> diff-mode: 0;

    in property <bool> plan-visible: false;
    in property <PlanSummary> plan-summary;
    in property <bool> applying: false;
    in property <string> last-result;

    in-out property <length> inline-viewport-y: 0;
    in-out property <length> sbs-viewport-y: 0;
    // Counts of rows that occupy non-zero space in each diff view. The total
    // is segments.length; the changed-only count drops kind==0 rows. We pick
    // the right one based on AppState.show-context and multiply by 18px to
    // get the real content height — matches what the renderer lays out.
    in property <int> inline-changed-count: 0;
    in property <int> sbs-changed-count: 0;

    in property <length> inline-content-height:
        18px * (show-context ? diff-segments.length : inline-changed-count);
    in property <length> sbs-content-height:
        18px * (show-context ? sbs-rows.length : sbs-changed-count);

    in-out property <string> filter-text;
    // Category filter: 0 = all, 1 = conflicts only, 2 = orphans only.
    in-out property <int> filter-category: 0;
    in-out property <bool> show-context: true;

    // Apply-scope: 0 = remap across all aircraft, 1 = remap selected aircraft only.
    in-out property <int> apply-scope: 0;
    // Number of aircraft the current selection would touch in "all aircraft" mode.
    in property <int> affected-aircraft-count: 0;
    // Other Active devices in the same aircraft+subtype as the selection.
    in property <[AircraftDevice]> aircraft-devices;
    // Aircraft folders that have the selected device configured.
    in property <[AffectedAircraft]> affected-aircraft;

    callback rescan();
    callback select-conflict(int);
    // (from-guid, to-guid, scope) — scope: 0 = all aircraft, 1 = single aircraft.
    callback request-plan(string, string, int);
    // Build a plan that processes every currently-filtered item. Each item
    // picks a sensible default mapping (orphan -> live, conflict -> live one
    // wins). User reviews the plan before confirming.
    callback request-bulk-plan();
    callback confirm-apply();
    callback cancel-apply();
    callback undo-last();
    callback filter-changed(string);
    callback category-changed(int);
}

// ---------------------------------------------------------- AppHeader ----
//
// Single compact header combining product name, scan summary, install path,
// DCS-running warning, and the top-level action buttons.

component AppHeader inherits Rectangle {
    height: 56px;
    background: GhTheme.t.surface;
    Rectangle {
        x: 0; y: parent.height - 1px;
        width: parent.width; height: 1px;
        background: GhTheme.t.border;
    }
    HorizontalBox {
        padding-left: 12px;
        padding-right: 12px;
        padding-top: 8px;
        padding-bottom: 8px;
        spacing: 12px;
        // Title block.
        VerticalBox {
            padding: 0;
            spacing: 2px;
            width: 220px;
            HorizontalBox {
                padding: 0;
                spacing: 6px;
                Text {
                    text: "DCSBinder";
                    font-size: 15px;
                    font-weight: 700;
                    color: GhTheme.t.text;
                    vertical-alignment: center;
                }
            }
            Text {
                text: AppState.status-text;
                font-size: 10px;
                color: GhTheme.t.text-muted;
                overflow: elide;
            }
        }
        // Install info (only first install shown inline; rare to have multiple).
        if AppState.installs.length > 0: VerticalBox {
            padding: 0;
            spacing: 2px;
            horizontal-stretch: 1;
            HorizontalBox {
                padding: 0;
                spacing: 6px;
                Text {
                    text: AppState.installs[0].label;
                    font-size: 11px;
                    font-weight: 600;
                    color: GhTheme.t.text;
                    vertical-alignment: center;
                }
                Text {
                    text: "·";
                    color: GhTheme.t.text-muted;
                    vertical-alignment: center;
                }
                Text {
                    text: "\{AppState.installs[0].aircraft-count} aircraft · \{AppState.installs[0].device-count} files";
                    font-size: 11px;
                    color: GhTheme.t.text-muted;
                    vertical-alignment: center;
                }
            }
            Text {
                text: AppState.installs[0].input-root;
                font-size: 10px;
                font-family: "Consolas";
                color: GhTheme.t.text-muted;
                overflow: elide;
            }
        }
        if AppState.installs.length == 0: Rectangle { horizontal-stretch: 1; }
        // DCS-running warning.
        if AppState.dcs-running: Rectangle {
            background: GhTheme.t.danger-soft;
            border-color: GhTheme.t.danger;
            border-width: 1px;
            border-radius: 6px;
            height: 32px;
            HorizontalBox {
                padding-left: 8px;
                padding-right: 10px;
                padding-top: 0;
                padding-bottom: 0;
                spacing: 6px;
                Image {
                    source: @image-url("icons/circle-alert.svg");
                    width: 14px;
                    height: 14px;
                    colorize: GhTheme.t.danger;
                    y: (parent.height - self.height) / 2;
                }
                Text {
                    text: "DCS.exe running (PID \{AppState.dcs-running-pid})";
                    font-size: 11px;
                    color: GhTheme.t.danger-text;
                    vertical-alignment: center;
                }
            }
        }
        Button {
            height: 32px;
            icon: @image-url("icons/refresh-cw.svg");
            colorize-icon: true;
            text: AppState.scanning ? "Scanning…" : "Rescan";
            enabled: !AppState.scanning && !AppState.applying;
            clicked => { AppState.rescan(); }
        }
        Button {
            height: 32px;
            icon: @image-url("icons/undo-2.svg");
            colorize-icon: true;
            text: "Undo last";
            enabled: !AppState.applying;
            clicked => { AppState.undo-last(); }
        }
    }
}

// ----------------------------------------------- ConflictsList ----

component ConflictsList inherits Rectangle {
    width: 460px;
    background: GhTheme.t.bg;
    Rectangle {
        x: parent.width - 1px; y: 0;
        width: 1px; height: parent.height;
        background: GhTheme.t.border;
    }
    VerticalBox {
        padding: 0;
        spacing: 0;
        Rectangle {
            height: 32px;
            background: GhTheme.t.surface;
            Rectangle {
                x: 0; y: parent.height - 1px;
                width: parent.width; height: 1px;
                background: GhTheme.t.border;
            }
            HorizontalBox {
                padding-left: 10px;
                Text {
                    text: AppState.conflicts.length + " actionable item(s)";
                    vertical-alignment: center;
                    font-weight: 600;
                    color: GhTheme.t.text;
                }
            }
        }
        Rectangle {
            height: 44px;
            background: GhTheme.t.bg;
            HorizontalBox {
                padding-left: 10px;
                padding-right: 10px;
                padding-top: 6px;
                padding-bottom: 6px;
                spacing: 6px;
                Image {
                    source: @image-url("icons/search.svg");
                    width: 16px;
                    height: 16px;
                    colorize: GhTheme.t.text-muted;
                    y: (parent.height - self.height) / 2;
                }
                LineEdit {
                    placeholder-text: "Filter by aircraft or device name…";
                    text <=> AppState.filter-text;
                    edited(text) => { AppState.filter-changed(text); }
                }
            }
        }
        ScrollView {
            vertical-scrollbar-policy: as-needed;
            VerticalBox {
                padding: 6px;
                spacing: 6px;
                for c[i] in AppState.conflicts: Rectangle {
                    background: AppState.selected-index == i ? GhTheme.t.accent-soft : GhTheme.t.bg;
                    border-radius: 6px;
                    border-color: AppState.selected-index == i
                        ? GhTheme.t.accent
                        : (c.is-orphan ? GhTheme.t.warning : GhTheme.t.border);
                    border-width: AppState.selected-index == i ? 2px : 1px;
                    TouchArea {
                        clicked => { AppState.select-conflict(i); }
                        VerticalBox {
                            padding: 8px;
                            spacing: 2px;
                            HorizontalBox {
                                padding: 0;
                                spacing: 6px;
                                Rectangle {
                                    width: chip-text.preferred-width + 12px;
                                    height: 18px;
                                    background: c.is-orphan ? GhTheme.t.warning-soft : GhTheme.t.accent-soft;
                                    border-radius: 9px;
                                    chip-text := Text {
                                        text: c.is-orphan ? "ORPHAN" : "CONFLICT";
                                        font-size: 10px;
                                        font-weight: 700;
                                        color: c.is-orphan ? GhTheme.t.warning : GhTheme.t.accent;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                                Text {
                                    text: c.aircraft + " / " + c.subtype;
                                    font-size: 11px;
                                    color: GhTheme.t.text-muted;
                                    vertical-alignment: center;
                                }
                            }
                            Text {
                                text: c.device-name;
                                font-weight: 700;
                                color: GhTheme.t.text;
                            }
                            HorizontalBox {
                                padding: 0;
                                spacing: 4px;
                                Rectangle {
                                    width: 46px;
                                    height: 16px;
                                    background: c.candidate-a-live ? GhTheme.t.diff-add-bg : GhTheme.t.surface-2;
                                    border-radius: 3px;
                                    Text {
                                        text: c.candidate-a-live ? "LIVE" : "STALE";
                                        font-size: 9px;
                                        font-weight: 700;
                                        color: c.candidate-a-live ? GhTheme.t.diff-add-symbol : GhTheme.t.text-muted;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                                Text {
                                    text: c.candidate-a-guid;
                                    font-size: 10px;
                                    font-family: "Consolas";
                                    color: GhTheme.t.text;
                                    vertical-alignment: center;
                                }
                            }
                            if !c.is-orphan: HorizontalBox {
                                padding: 0;
                                spacing: 4px;
                                Rectangle {
                                    width: 46px;
                                    height: 16px;
                                    background: c.candidate-b-live ? GhTheme.t.diff-add-bg : GhTheme.t.surface-2;
                                    border-radius: 3px;
                                    Text {
                                        text: c.candidate-b-live ? "LIVE" : "STALE";
                                        font-size: 9px;
                                        font-weight: 700;
                                        color: c.candidate-b-live ? GhTheme.t.diff-add-symbol : GhTheme.t.text-muted;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                                Text {
                                    text: c.candidate-b-guid;
                                    font-size: 10px;
                                    font-family: "Consolas";
                                    color: GhTheme.t.text;
                                    vertical-alignment: center;
                                }
                            }
                            if c.is-orphan: HorizontalBox {
                                padding: 0;
                                spacing: 4px;
                                Rectangle {
                                    width: 46px;
                                    height: 16px;
                                    background: GhTheme.t.diff-add-bg;
                                    border-radius: 3px;
                                    Text {
                                        text: "LIVE";
                                        font-size: 9px;
                                        font-weight: 700;
                                        color: GhTheme.t.diff-add-symbol;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                                Text {
                                    text: c.orphan-target-guid + "  (no file yet)";
                                    font-size: 10px;
                                    font-family: "Consolas";
                                    color: GhTheme.t.text;
                                    vertical-alignment: center;
                                }
                            }
                            if c.extra-candidates > 0: Text {
                                text: "+ " + c.extra-candidates + " other stale GUID(s)";
                                font-size: 10px;
                                color: GhTheme.t.text-muted;
                            }
                        }
                    }
                }
                if AppState.conflicts.length == 0: Text {
                    text: AppState.scanning ? "Scanning..." : "No conflicts or orphans detected.";
                    color: GhTheme.t.text-muted;
                    horizontal-alignment: center;
                }
            }
        }
    }
}

// ------------------------------------------------------- Minimap ----
//
// Combines change markers + scrollbar thumb into a single 18px-wide strip
// on the far right of the diff pane. The default ScrollView scrollbars are
// hidden so this strip is the only scroll affordance.

component InlineMinimap inherits Rectangle {
    width: 18px;
    background: GhTheme.t.surface;

    // Scrollbar math. `self.height` is the bar height AND the diff viewport
    // height (they're sibling children of the same HorizontalBox).
    property <length> content-h: AppState.inline-content-height;
    property <length> visible-h: self.height;
    property <length> max-scroll: max(content-h - visible-h, 0px);
    property <length> thumb-h:
        content-h > 0px
            ? max(20px, clamp(visible-h / content-h, 0.0, 1.0) * self.height)
            : 0px;
    property <length> max-thumb-top: max(self.height - thumb-h, 0px);
    // 0..1 — scroll progress.
    property <float> progress:
        max-scroll > 0px ? -AppState.inline-viewport-y / max-scroll : 0;

    Rectangle {
        x: 0; y: 0;
        width: 1px; height: parent.height;
        background: GhTheme.t.border;
    }
    // Change markers — use the same pastel tones as the in-doc row
    // highlighting so the bar reads as a continuation of the diff.
    for seg[i] in AppState.diff-segments: Rectangle {
        x: 2px;
        y: (i * 1.0 / max(AppState.diff-segments.length, 1)) * parent.height;
        width: parent.width - 4px;
        height: max(1.5px, parent.height / max(AppState.diff-segments.length, 1));
        background: seg.kind == 0 ? transparent
                  : seg.kind == 1 ? GhTheme.t.diff-add-bg
                  : seg.kind == 2 ? GhTheme.t.diff-del-bg
                  :                 GhTheme.t.diff-hunk-bg;
    }
    // Scrollbar thumb.
    Rectangle {
        x: 1px;
        y: progress * max-thumb-top;
        width: parent.width - 2px;
        height: thumb-h;
        background: ta.has-hover || ta.pressed ? #00000038 : #00000020;
        border-color: ta.pressed ? GhTheme.t.accent : #00000050;
        border-width: 1px;
        border-radius: 4px;
        animate background { duration: 80ms; }
    }
    ta := TouchArea {
        function set-scroll-from-y(y: length) {
            let target-thumb-top: length = clamp(y - thumb-h / 2, 0px, max-thumb-top);
            let p: float = max-thumb-top > 0px ? target-thumb-top / max-thumb-top : 0;
            AppState.inline-viewport-y = -p * max-scroll;
        }
        clicked => { set-scroll-from-y(self.mouse-y); }
        moved => { if (self.pressed) { set-scroll-from-y(self.mouse-y); } }
    }
}

component SbsMinimap inherits Rectangle {
    width: 18px;
    background: GhTheme.t.surface;

    property <length> content-h: AppState.sbs-content-height;
    property <length> visible-h: self.height;
    property <length> max-scroll: max(content-h - visible-h, 0px);
    property <length> thumb-h:
        content-h > 0px
            ? max(20px, clamp(visible-h / content-h, 0.0, 1.0) * self.height)
            : 0px;
    property <length> max-thumb-top: max(self.height - thumb-h, 0px);
    property <float> progress:
        max-scroll > 0px ? -AppState.sbs-viewport-y / max-scroll : 0;

    Rectangle {
        x: 0; y: 0;
        width: 1px; height: parent.height;
        background: GhTheme.t.border;
    }
    for row[i] in AppState.sbs-rows: Rectangle {
        x: 2px;
        y: (i * 1.0 / max(AppState.sbs-rows.length, 1)) * parent.height;
        width: parent.width - 4px;
        height: max(1.5px, parent.height / max(AppState.sbs-rows.length, 1));
        background:
              row.header-kind == 3                          ? GhTheme.t.diff-hunk-bg
            : (row.left-kind == 1 && row.right-kind == 1)   ? GhTheme.t.warning-soft
            :  row.left-kind == 1                           ? GhTheme.t.diff-del-bg
            :  row.right-kind == 1                          ? GhTheme.t.diff-add-bg
            :                                                 transparent;
    }
    Rectangle {
        x: 1px;
        y: progress * max-thumb-top;
        width: parent.width - 2px;
        height: thumb-h;
        background: ta.has-hover || ta.pressed ? #00000038 : #00000020;
        border-color: ta.pressed ? GhTheme.t.accent : #00000050;
        border-width: 1px;
        border-radius: 4px;
        animate background { duration: 80ms; }
    }
    ta := TouchArea {
        function set-scroll-from-y(y: length) {
            let target-thumb-top: length = clamp(y - thumb-h / 2, 0px, max-thumb-top);
            let p: float = max-thumb-top > 0px ? target-thumb-top / max-thumb-top : 0;
            AppState.sbs-viewport-y = -p * max-scroll;
        }
        clicked => { set-scroll-from-y(self.mouse-y); }
        moved => { if (self.pressed) { set-scroll-from-y(self.mouse-y); } }
    }
}

// ---------------------------------------------------- DiffPane ----

component DiffPane inherits Rectangle {
    background: GhTheme.t.bg;
    VerticalBox {
        padding: 0;
        spacing: 0;
        Rectangle {
            height: 40px;
            background: GhTheme.t.surface;
            Rectangle {
                x: 0; y: parent.height - 1px;
                width: parent.width; height: 1px;
                background: GhTheme.t.border;
            }
            HorizontalBox {
                padding-left: 10px;
                padding-right: 8px;
                spacing: 6px;
                Text {
                    text: "Diff";
                    vertical-alignment: center;
                    font-weight: 600;
                    color: GhTheme.t.text;
                }
                Rectangle { horizontal-stretch: 1; }
                Button {
                    height: 32px;
                    icon: @image-url("icons/align-left.svg");
                    colorize-icon: true;
                    text: "Inline";
                    primary: AppState.diff-mode == 0;
                    clicked => { AppState.diff-mode = 0; }
                }
                Button {
                    height: 32px;
                    icon: @image-url("icons/columns-2.svg");
                    colorize-icon: true;
                    text: "Split";
                    primary: AppState.diff-mode == 1;
                    clicked => { AppState.diff-mode = 1; }
                }
                Button {
                    height: 32px;
                    icon: @image-url("icons/list-filter.svg");
                    colorize-icon: true;
                    text: AppState.show-context ? "All lines" : "Changed only";
                    primary: !AppState.show-context;
                    clicked => { AppState.show-context = !AppState.show-context; }
                }
            }
        }
        HorizontalBox {
            padding: 0;
            spacing: 0;
            Rectangle {
                horizontal-stretch: 1;
                background: GhTheme.t.bg;
                if AppState.diff-mode == 0: ScrollView {
                    x: 0; y: 0; width: parent.width; height: parent.height;
                    viewport-y <=> AppState.inline-viewport-y;
                    vertical-scrollbar-policy: always-off;
                    horizontal-scrollbar-policy: always-off;
                    VerticalBox {
                        padding: 0;
                        spacing: 0;
                        if AppState.diff-segments.length == 0: Text {
                            text: "Select an item on the left to see its diff.";
                            color: GhTheme.t.text-muted;
                            horizontal-alignment: center;
                        }
                        for seg[i] in AppState.diff-segments: Rectangle {
                            height: (seg.kind == 0 && !AppState.show-context) ? 0px : 18px;
                            visible: seg.kind != 0 || AppState.show-context;
                            clip: true;
                            background:
                                seg.kind == 3 ? GhTheme.t.diff-hunk-bg
                              : seg.kind == 1 ? GhTheme.t.diff-add-bg
                              : seg.kind == 2 ? GhTheme.t.diff-del-bg
                              :                 GhTheme.t.bg;
                            HorizontalBox {
                                padding: 0;
                                spacing: 0;
                                Rectangle {
                                    width: 48px;
                                    background:
                                        seg.kind == 3 ? GhTheme.t.diff-hunk-bg
                                      : seg.kind == 2 ? GhTheme.t.diff-del-gutter
                                      :                 GhTheme.t.surface;
                                    Text {
                                        x: 0;
                                        width: parent.width - 8px;
                                        horizontal-alignment: right;
                                        text: seg.line-a > 0 ? "\{seg.line-a}" : "";
                                        font-family: "Consolas";
                                        font-size: 11px;
                                        color: GhTheme.t.diff-line-num;
                                        vertical-alignment: center;
                                    }
                                }
                                Rectangle {
                                    width: 48px;
                                    background:
                                        seg.kind == 3 ? GhTheme.t.diff-hunk-bg
                                      : seg.kind == 1 ? GhTheme.t.diff-add-gutter
                                      :                 GhTheme.t.surface;
                                    Text {
                                        x: 0;
                                        width: parent.width - 8px;
                                        horizontal-alignment: right;
                                        text: seg.line-b > 0 ? "\{seg.line-b}" : "";
                                        font-family: "Consolas";
                                        font-size: 11px;
                                        color: GhTheme.t.diff-line-num;
                                        vertical-alignment: center;
                                    }
                                }
                                Rectangle {
                                    horizontal-stretch: 1;
                                    clip: true;
                                    Text {
                                        x: 6px;
                                        text: seg.kind == 3 ? seg.text
                                            : (seg.kind == 1 ? "+ " : seg.kind == 2 ? "- " : "  ") + seg.text;
                                        font-family: "Consolas";
                                        font-size: 11px;
                                        color: seg.kind == 3 ? GhTheme.t.diff-hunk-text
                                            : seg.kind == 1 ? GhTheme.t.diff-add-symbol
                                            : seg.kind == 2 ? GhTheme.t.diff-del-symbol
                                            :                 GhTheme.t.diff-code;
                                        overflow: clip;
                                        wrap: no-wrap;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }
                if AppState.diff-mode == 1: ScrollView {
                    x: 0; y: 0; width: parent.width; height: parent.height;
                    viewport-y <=> AppState.sbs-viewport-y;
                    vertical-scrollbar-policy: always-off;
                    horizontal-scrollbar-policy: always-off;
                    VerticalBox {
                        padding: 0;
                        spacing: 0;
                        if AppState.sbs-rows.length == 0: Text {
                            text: "Select an item on the left to see its diff.";
                            color: GhTheme.t.text-muted;
                            horizontal-alignment: center;
                        }
                        for row[i] in AppState.sbs-rows: Rectangle {
                            height:
                                (row.header-kind == 0
                                 && row.left-kind == 0
                                 && row.right-kind == 0
                                 && !AppState.show-context) ? 0px : 18px;
                            visible:
                                row.header-kind != 0
                                || row.left-kind != 0
                                || row.right-kind != 0
                                || AppState.show-context;
                            clip: true;
                            if row.header-kind == 3: Rectangle {
                                background: GhTheme.t.diff-hunk-bg;
                                Text {
                                    x: 6px;
                                    text: row.header-text;
                                    font-family: "Consolas";
                                    font-size: 11px;
                                    color: GhTheme.t.diff-hunk-text;
                                    vertical-alignment: center;
                                }
                            }
                            if row.header-kind == 0: HorizontalBox {
                                padding: 0;
                                spacing: 0;
                                Rectangle {
                                    width: 44px;
                                    background:
                                        row.left-kind == 1 ? GhTheme.t.diff-del-gutter
                                      :                      GhTheme.t.surface;
                                    Text {
                                        x: 0;
                                        width: parent.width - 8px;
                                        horizontal-alignment: right;
                                        text: row.line-a > 0 ? "\{row.line-a}" : "";
                                        font-family: "Consolas";
                                        font-size: 11px;
                                        color: GhTheme.t.diff-line-num;
                                        vertical-alignment: center;
                                    }
                                }
                                Rectangle {
                                    horizontal-stretch: 1;
                                    clip: true;
                                    background:
                                        row.left-kind == 2 ? GhTheme.t.surface
                                      : row.left-kind == 1 ? GhTheme.t.diff-del-bg
                                      :                      GhTheme.t.bg;
                                    Text {
                                        x: 6px;
                                        text: row.left-text;
                                        font-family: "Consolas";
                                        font-size: 11px;
                                        color: row.left-kind == 1
                                            ? GhTheme.t.diff-del-symbol
                                            : GhTheme.t.diff-code;
                                        overflow: clip;
                                        wrap: no-wrap;
                                        vertical-alignment: center;
                                    }
                                }
                                Rectangle { width: 1px; background: GhTheme.t.border; }
                                Rectangle {
                                    width: 44px;
                                    background:
                                        row.right-kind == 1 ? GhTheme.t.diff-add-gutter
                                      :                       GhTheme.t.surface;
                                    Text {
                                        x: 0;
                                        width: parent.width - 8px;
                                        horizontal-alignment: right;
                                        text: row.line-b > 0 ? "\{row.line-b}" : "";
                                        font-family: "Consolas";
                                        font-size: 11px;
                                        color: GhTheme.t.diff-line-num;
                                        vertical-alignment: center;
                                    }
                                }
                                Rectangle {
                                    horizontal-stretch: 1;
                                    clip: true;
                                    background:
                                        row.right-kind == 2 ? GhTheme.t.surface
                                      : row.right-kind == 1 ? GhTheme.t.diff-add-bg
                                      :                       GhTheme.t.bg;
                                    Text {
                                        x: 6px;
                                        text: row.right-text;
                                        font-family: "Consolas";
                                        font-size: 11px;
                                        color: row.right-kind == 1
                                            ? GhTheme.t.diff-add-symbol
                                            : GhTheme.t.diff-code;
                                        overflow: clip;
                                        wrap: no-wrap;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }
            }
            if AppState.diff-mode == 0: InlineMinimap {}
            if AppState.diff-mode == 1: SbsMinimap {}
        }
    }
}

// ------------------------------------------------- DetailHeader ----

component DetailHeader inherits Rectangle {
    height: 60px;
    background: GhTheme.t.surface;
    Rectangle {
        x: 0; y: parent.height - 1px;
        width: parent.width; height: 1px;
        background: GhTheme.t.border;
    }
    HorizontalBox {
        padding-left: 12px;
        padding-right: 10px;
        spacing: 10px;
        VerticalBox {
            padding: 0;
            spacing: 2px;
            Text {
                text: AppState.selected-index >= 0
                    ? AppState.conflicts[AppState.selected-index].device-name
                    : "Select an item on the left";
                font-weight: 700;
                font-size: 14px;
                color: GhTheme.t.text;
            }
            Text {
                text: AppState.selected-index >= 0
                    ? AppState.conflicts[AppState.selected-index].aircraft + " / " + AppState.conflicts[AppState.selected-index].subtype
                    : "";
                font-size: 11px;
                color: GhTheme.t.text-muted;
            }
        }
        Rectangle { horizontal-stretch: 1; }
        // Apply-scope cycle button.
        if AppState.selected-index >= 0: Button {
            height: 32px;
            icon: AppState.apply-scope == 0
                ? @image-url("icons/layers.svg")
                : @image-url("icons/target.svg");
            colorize-icon: true;
            text: AppState.apply-scope == 0
                ? "All aircraft (\{AppState.affected-aircraft-count})"
                : "This aircraft only";
            clicked => {
                AppState.apply-scope = (AppState.apply-scope + 1).mod(2);
            }
        }
        if AppState.selected-index >= 0 && !AppState.conflicts[AppState.selected-index].is-orphan: Button {
            height: 32px;
            text: "Use A (" + (AppState.conflicts[AppState.selected-index].candidate-a-live ? "live" : "stale") + ")";
            enabled: !AppState.dcs-running && !AppState.applying;
            clicked => {
                AppState.request-plan(
                    AppState.conflicts[AppState.selected-index].candidate-a-guid,
                    AppState.conflicts[AppState.selected-index].candidate-b-live
                        ? AppState.conflicts[AppState.selected-index].candidate-b-guid
                        : AppState.conflicts[AppState.selected-index].candidate-a-guid,
                    AppState.apply-scope
                );
            }
        }
        if AppState.selected-index >= 0 && !AppState.conflicts[AppState.selected-index].is-orphan: Button {
            height: 32px;
            text: "Use B (" + (AppState.conflicts[AppState.selected-index].candidate-b-live ? "live" : "stale") + ")";
            enabled: !AppState.dcs-running && !AppState.applying;
            clicked => {
                AppState.request-plan(
                    AppState.conflicts[AppState.selected-index].candidate-b-guid,
                    AppState.conflicts[AppState.selected-index].candidate-a-live
                        ? AppState.conflicts[AppState.selected-index].candidate-a-guid
                        : AppState.conflicts[AppState.selected-index].candidate-b-guid,
                    AppState.apply-scope
                );
            }
        }
        if AppState.selected-index >= 0 && AppState.conflicts[AppState.selected-index].is-orphan: Button {
            height: 32px;
            text: "Remap to live";
            primary: true;
            enabled: !AppState.dcs-running && !AppState.applying;
            clicked => {
                AppState.request-plan(
                    AppState.conflicts[AppState.selected-index].candidate-a-guid,
                    AppState.conflicts[AppState.selected-index].orphan-target-guid,
                    AppState.apply-scope
                );
            }
        }
    }
}

// Strip under the detail header showing every aircraft folder that has the
// SELECTED device configured. These are the aircraft a remap would touch
// when "Apply: all aircraft" is selected; the user's current aircraft is
// highlighted distinctly.
component AffectsAircraftStrip inherits Rectangle {
    height: AppState.affected-aircraft.length > 0 ? 36px : 0px;
    visible: AppState.affected-aircraft.length > 0;
    background: GhTheme.t.bg;
    Rectangle {
        x: 0; y: parent.height - 1px;
        width: parent.width; height: 1px;
        background: GhTheme.t.border;
    }
    HorizontalBox {
        padding-left: 12px;
        padding-right: 12px;
        padding-top: 0;
        padding-bottom: 0;
        spacing: 6px;
        Text {
            text: "Affects:";
            font-size: 11px;
            color: GhTheme.t.text-muted;
            vertical-alignment: center;
            width: 50px;
        }
        Flickable {
            horizontal-stretch: 1;
            viewport-width: ctx-row.preferred-width;
            ctx-row := HorizontalBox {
                padding: 0;
                spacing: 4px;
                for a[i] in AppState.affected-aircraft: Rectangle {
                    height: 22px;
                    y: (parent.height - self.height) / 2;
                    border-radius: 11px;
                    border-width: a.is-selected ? 2px : 1px;
                    border-color: a.is-selected ? GhTheme.t.accent : GhTheme.t.border;
                    background: a.is-selected ? GhTheme.t.accent-soft : GhTheme.t.surface;
                    HorizontalBox {
                        padding-left: 10px;
                        padding-right: 10px;
                        Text {
                            text: a.name;
                            font-size: 11px;
                            font-weight: a.is-selected ? 700 : 400;
                            color: a.is-selected ? GhTheme.t.accent : GhTheme.t.text;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}

// ------------------------------------------------- PlanDialog ----

component PlanDialog inherits Rectangle {
    background: #00000060;
    VerticalBox {
        padding: 0;
        spacing: 0;
        Rectangle { vertical-stretch: 1; }
        HorizontalBox {
            padding: 0;
            spacing: 0;
            Rectangle { horizontal-stretch: 1; }
            Rectangle {
                background: GhTheme.t.bg;
                border-color: GhTheme.t.border;
                border-width: 1px;
                border-radius: 8px;
                width: 720px;
                height: dialog-content.preferred-height + 24px;
                dialog-content := VerticalBox {
                    padding: 16px;
                    spacing: 8px;
                    // Title row.
                    HorizontalBox {
                        padding: 0;
                        spacing: 10px;
                        Text {
                            text: "Confirm remap";
                            font-size: 15px;
                            font-weight: 700;
                            color: GhTheme.t.text;
                            vertical-alignment: center;
                        }
                        Rectangle { horizontal-stretch: 1; }
                        Text {
                            text: "\{AppState.plan-summary.aircraft-count} aircraft · \{AppState.plan-summary.mutation-count} mutations";
                            font-size: 11px;
                            color: GhTheme.t.text-muted;
                            vertical-alignment: center;
                        }
                    }
                    Rectangle {
                        height: 1px;
                        background: GhTheme.t.border-muted;
                    }
                    // Two compact rows: device + GUID pair.
                    HorizontalBox {
                        padding: 0;
                        spacing: 6px;
                        Text {
                            text: "Device";
                            font-size: 11px;
                            width: 50px;
                            color: GhTheme.t.text-muted;
                            vertical-alignment: center;
                        }
                        Text {
                            text: AppState.plan-summary.device-name;
                            font-size: 12px;
                            font-weight: 700;
                            color: GhTheme.t.text;
                            vertical-alignment: center;
                        }
                    }
                    HorizontalBox {
                        padding: 0;
                        spacing: 6px;
                        Text {
                            text: "From";
                            font-size: 11px;
                            width: 50px;
                            color: GhTheme.t.text-muted;
                            vertical-alignment: center;
                        }
                        Text {
                            text: AppState.plan-summary.from-guid;
                            font-family: "Consolas";
                            font-size: 11px;
                            color: GhTheme.t.text;
                            vertical-alignment: center;
                        }
                    }
                    HorizontalBox {
                        padding: 0;
                        spacing: 6px;
                        Text {
                            text: "To";
                            font-size: 11px;
                            width: 50px;
                            color: GhTheme.t.text-muted;
                            vertical-alignment: center;
                        }
                        Text {
                            text: AppState.plan-summary.to-guid;
                            font-family: "Consolas";
                            font-size: 11px;
                            color: GhTheme.t.diff-add-symbol;
                            font-weight: 700;
                            vertical-alignment: center;
                        }
                    }
                    HorizontalBox {
                        padding: 0;
                        spacing: 6px;
                        Text {
                            text: "Backup";
                            font-size: 11px;
                            width: 50px;
                            color: GhTheme.t.text-muted;
                            vertical-alignment: center;
                        }
                        Text {
                            text: AppState.plan-summary.backup-dir;
                            font-family: "Consolas";
                            font-size: 10px;
                            color: GhTheme.t.text-muted;
                            vertical-alignment: center;
                            overflow: elide;
                            horizontal-stretch: 1;
                        }
                    }
                    Rectangle {
                        height: 1px;
                        background: GhTheme.t.border-muted;
                    }
                    Text {
                        text: "Mutations (\{AppState.plan-summary.lines.length})";
                        font-size: 11px;
                        font-weight: 600;
                        color: GhTheme.t.text-muted;
                    }
                    Rectangle {
                        height: 220px;
                        background: GhTheme.t.surface;
                        border-color: GhTheme.t.border;
                        border-width: 1px;
                        border-radius: 6px;
                        ScrollView {
                            x: 1px; y: 1px;
                            width: parent.width - 2px;
                            height: parent.height - 2px;
                            VerticalBox {
                                padding: 6px;
                                spacing: 0;
                                for line[i] in AppState.plan-summary.lines: Text {
                                    text: line;
                                    font-family: "Consolas";
                                    font-size: 10px;
                                    color: GhTheme.t.text;
                                    overflow: elide;
                                    height: 14px;
                                }
                            }
                        }
                    }
                    if AppState.last-result != "": Text {
                        text: AppState.last-result;
                        font-size: 11px;
                        color: GhTheme.t.text;
                        wrap: word-wrap;
                    }
                    HorizontalBox {
                        padding: 0;
                        padding-top: 4px;
                        spacing: 8px;
                        Rectangle { horizontal-stretch: 1; }
                        Button {
                            height: 32px;
                            icon: @image-url("icons/x.svg");
                            colorize-icon: true;
                            text: "Cancel";
                            clicked => { AppState.cancel-apply(); }
                        }
                        Button {
                            height: 32px;
                            icon: @image-url("icons/check.svg");
                            colorize-icon: true;
                            text: AppState.applying ? "Applying…" : "Confirm — apply remap";
                            primary: true;
                            enabled: !AppState.applying && !AppState.dcs-running;
                            clicked => { AppState.confirm-apply(); }
                        }
                    }
                }
            }
            Rectangle { horizontal-stretch: 1; }
        }
        Rectangle { vertical-stretch: 1; }
    }
}

// ------------------------------------------------------- App ----

export component App inherits Window {
    title: "DCSBinder";
    preferred-width: 1280px;
    preferred-height: 800px;
    min-width: 900px;
    min-height: 540px;
    background: GhTheme.t.bg;

    init => {
        Palette.color-scheme = ColorScheme.light;
    }

    VerticalBox {
        padding: 0;
        spacing: 0;
        AppHeader {}
        HorizontalBox {
            padding: 0;
            spacing: 0;
            ConflictsList {}
            VerticalBox {
                padding: 0;
                spacing: 0;
                DetailHeader {}
                AffectsAircraftStrip {}
                DiffPane {
                    vertical-stretch: 1;
                }
            }
        }
    }

    if AppState.plan-visible: PlanDialog {
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
    }
}
