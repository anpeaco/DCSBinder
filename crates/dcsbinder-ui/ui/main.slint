// DCSBinder UI — M4 v1.
//
// Single window, three panels:
//  - Top: status bar (install paths, scan summary, rescan).
//  - Left: list of actionable items (conflicts + orphans).
//  - Right: detail pane with side-by-side diff and Apply button.

import { VerticalBox, HorizontalBox, GroupBox, Button, ListView, ScrollView, LineEdit,
         StandardListView, TextEdit, StandardButton, Palette } from "std-widgets.slint";

struct InstallInfo {
    label: string,
    input-root: string,
    aircraft-count: int,
    device-count: int,
}

struct ConflictRow {
    aircraft: string,
    device-name: string,
    subtype: string,
    // Two candidates; if >2 the UI shows a hint.
    candidate-a-guid: string,
    candidate-a-live: bool,
    candidate-b-guid: string,
    candidate-b-live: bool,
    extra-candidates: int,
    // For orphan rows: there's only one stale candidate and a live target GUID
    // not represented by any file.
    is-orphan: bool,
    orphan-target-guid: string,
}

struct DiffSegment {
    text: string,
    // 0 = context (unchanged), 1 = added (right only), 2 = removed (left only),
    // 3 = hunk header (@@ -N,M +N,M @@).
    kind: int,
    // 1-based line numbers in each source. -1 means "no number on this side".
    line-a: int,
    line-b: int,
}

struct SbsRow {
    left-text: string,
    right-text: string,
    // 0 = context, 1 = changed, 2 = blank (padding row).
    left-kind: int,
    right-kind: int,
    line-a: int,
    line-b: int,
    // 3 = hunk header — spans both columns when set.
    header-kind: int,
    header-text: string,
}

struct PlanSummary {
    device-name: string,
    from-guid: string,
    to-guid: string,
    aircraft-count: int,
    mutation-count: int,
    backup-dir: string,
    lines: [string],
}

export global AppState {
    in property <[InstallInfo]> installs;
    in property <[ConflictRow]> conflicts;
    in property <string> status-text;
    in property <bool> scanning;
    in property <bool> dcs-running;
    in property <int> dcs-running-pid;

    in property <int> selected-index: -1;
    in property <string> selected-source-content;
    in property <string> selected-target-content;
    in property <[DiffSegment]> diff-segments;
    in property <[SbsRow]> sbs-rows;
    // 0 = inline (unified), 1 = side-by-side.
    in-out property <int> diff-mode: 0;

    in property <bool> plan-visible: false;
    in property <PlanSummary> plan-summary;
    in property <bool> applying: false;
    in property <string> last-result;

    // Two-way scroll state for the diff pane (so the minimap can drive scroll
    // and show a viewport thumb).
    in-out property <length> inline-viewport-y: 0;
    in-out property <length> sbs-viewport-y: 0;
    // Heights of the actual content (pixel-accurate; we know each row is 18px).
    in property <length> inline-content-height: 18px * AppState.diff-segments.length;
    in property <length> sbs-content-height: 18px * AppState.sbs-rows.length;
    // The currently-visible diff viewport pixel height. Each ScrollView
    // assigns its own visible-height into this so the minimap can size its thumb.
    in-out property <length> diff-visible-height: 0;

    // Conflicts filter (case-insensitive substring across aircraft + device-name).
    in-out property <string> filter-text;

    // Diff view: when false, context rows (kind == 0) are hidden.
    in-out property <bool> show-context: true;

    callback rescan();
    callback select-conflict(int);
    // (from_guid, to_guid) — Rust resolves the rest from the selected conflict.
    callback request-plan(string, string);
    callback confirm-apply();
    callback cancel-apply();
    callback undo-last();
    callback filter-changed(string);
}

component StatusBar inherits Rectangle {
    background: Palette.alternate-background;
    height: 56px;
    HorizontalBox {
        spacing: 12px;
        VerticalBox {
            padding: 0;
            spacing: 2px;
            Text {
                text: "DCSBinder";
                font-size: 16px;
                font-weight: 700;
            }
            Text {
                text: AppState.status-text;
                font-size: 11px;
                color: Palette.foreground.with-alpha(0.7);
            }
        }
        // Stretch.
        Rectangle { horizontal-stretch: 1; }
        if AppState.dcs-running: Rectangle {
            background: #6e1010;
            border-radius: 4px;
            HorizontalBox {
                padding-left: 8px;
                padding-right: 10px;
                spacing: 6px;
                Image {
                    source: @image-url("icons/circle-alert.svg");
                    width: 16px;
                    height: 16px;
                    colorize: #ffffff;
                }
                Text {
                    text: "DCS.exe is running (PID " + AppState.dcs-running-pid + ") — remap disabled";
                    color: white;
                    vertical-alignment: center;
                }
            }
        }
        Button {
            icon: @image-url("icons/refresh-cw.svg");
            text: AppState.scanning ? "Scanning..." : "Rescan";
            enabled: !AppState.scanning && !AppState.applying;
            clicked => { AppState.rescan(); }
        }
        Button {
            icon: @image-url("icons/undo-2.svg");
            text: "Undo last";
            enabled: !AppState.applying;
            clicked => { AppState.undo-last(); }
        }
    }
}

component InstallsPanel inherits Rectangle {
    height: 32px + installs-vbox.preferred-height;
    background: Palette.background;
    border-color: Palette.border;
    border-width: 1px;
    installs-vbox := VerticalBox {
        padding: 8px;
        spacing: 4px;
        for inst[i] in AppState.installs: HorizontalBox {
            padding: 0;
            spacing: 8px;
            Text {
                text: inst.label;
                font-weight: 700;
                width: 130px;
                vertical-alignment: center;
            }
            Text {
                text: inst.input-root;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }
            Text {
                text: inst.aircraft-count + " aircraft · " + inst.device-count + " files";
                color: Palette.foreground.with-alpha(0.7);
                vertical-alignment: center;
            }
        }
        if AppState.installs.length == 0: Text {
            text: "No DCS installs discovered. Did you launch DCS at least once?";
            color: Palette.foreground.with-alpha(0.7);
        }
    }
}

component ConflictsList inherits Rectangle {
    width: 460px;
    background: Palette.background;
    border-color: Palette.border;
    border-width: 1px;
    VerticalBox {
        padding: 0;
        spacing: 0;
        Rectangle {
            height: 32px;
            background: Palette.alternate-background;
            HorizontalBox {
                padding-left: 10px;
                Text {
                    text: AppState.conflicts.length + " actionable item(s)";
                    vertical-alignment: center;
                    font-weight: 600;
                }
            }
        }
        Rectangle {
            height: 40px;
            background: Palette.background;
            HorizontalBox {
                padding-left: 8px;
                padding-right: 8px;
                padding-top: 4px;
                padding-bottom: 4px;
                LineEdit {
                    placeholder-text: "Filter by aircraft or device name...";
                    text <=> AppState.filter-text;
                    edited(text) => { AppState.filter-changed(text); }
                }
            }
        }
        ScrollView {
            VerticalBox {
                padding: 6px;
                spacing: 6px;
                for c[i] in AppState.conflicts: Rectangle {
                    background: AppState.selected-index == i ? #2a4060 : Palette.alternate-background;
                    border-radius: 4px;
                    border-color: AppState.selected-index == i
                        ? #6cb0ff
                        : (c.is-orphan ? #b07e1a : Palette.border);
                    border-width: AppState.selected-index == i ? 2px : 1px;
                    TouchArea {
                        clicked => { AppState.select-conflict(i); }
                        VerticalBox {
                            padding: 8px;
                            spacing: 2px;
                            HorizontalBox {
                                padding: 0;
                                spacing: 6px;
                                Text {
                                    text: c.is-orphan ? "[ORPHAN] " : "[CONFLICT] ";
                                    font-size: 10px;
                                    font-weight: 700;
                                    color: c.is-orphan ? #b07e1a : Palette.accent-foreground;
                                }
                                Text {
                                    text: c.aircraft + " / " + c.subtype;
                                    font-size: 11px;
                                    color: Palette.foreground.with-alpha(0.7);
                                }
                            }
                            Text {
                                text: c.device-name;
                                font-weight: 700;
                            }
                            Text {
                                text: (c.candidate-a-live ? "[LIVE]  " : "[STALE] ") + c.candidate-a-guid;
                                font-size: 10px;
                                color: c.candidate-a-live ? #2a8c3a : Palette.foreground.with-alpha(0.7);
                                font-family: "Consolas";
                            }
                            if !c.is-orphan: Text {
                                text: (c.candidate-b-live ? "[LIVE]  " : "[STALE] ") + c.candidate-b-guid;
                                font-size: 10px;
                                color: c.candidate-b-live ? #2a8c3a : Palette.foreground.with-alpha(0.7);
                                font-family: "Consolas";
                            }
                            if c.is-orphan: Text {
                                text: "[LIVE]  " + c.orphan-target-guid + "  (no file yet)";
                                font-size: 10px;
                                color: #2a8c3a;
                                font-family: "Consolas";
                            }
                            if c.extra-candidates > 0: Text {
                                text: "+ " + c.extra-candidates + " other stale GUID(s)";
                                font-size: 10px;
                                color: Palette.foreground.with-alpha(0.6);
                            }
                        }
                    }
                }
                if AppState.conflicts.length == 0: Text {
                    text: AppState.scanning
                        ? "Scanning..."
                        : "No conflicts or orphans detected.";
                    color: Palette.foreground.with-alpha(0.7);
                    horizontal-alignment: center;
                }
            }
        }
    }
}

// Thin vertical "minimap" / change-bar shown beside the diff scroll area.
// Each non-context line in the diff produces a colored mark proportional to
// its position in the full diff. Click anywhere on the strip to jump-scroll.
// A semi-transparent thumb shows the current viewport position.
component InlineMinimap inherits Rectangle {
    width: 14px;
    background: #15181c;
    border-color: Palette.border;
    border-width: 1px;
    // Change markers.
    for seg[i] in AppState.diff-segments: Rectangle {
        x: 2px;
        y: (i * 1.0 / max(AppState.diff-segments.length, 1)) * parent.height;
        width: parent.width - 4px;
        height: max(1.5px,
            parent.height / max(AppState.diff-segments.length, 1));
        background: seg.kind == 0 ? transparent
                  : seg.kind == 1 ? #6cd07c
                  :                 #ec7c7c;
    }
    // Viewport thumb.
    Rectangle {
        x: 0;
        y: AppState.inline-content-height > 0
            ? (-AppState.inline-viewport-y / AppState.inline-content-height) * parent.height
            : 0;
        width: parent.width;
        height: AppState.inline-content-height > 0
            ? max(8px, (AppState.diff-visible-height / AppState.inline-content-height) * parent.height)
            : 0;
        background: #ffffff20;
        border-color: #ffffff60;
        border-width: 1px;
    }
    // Click-to-scroll.
    TouchArea {
        clicked => {
            // Center the click position in the viewport.
            AppState.inline-viewport-y =
                -((self.mouse-y / parent.height) * AppState.inline-content-height
                  - AppState.diff-visible-height / 2);
        }
    }
}

component SbsMinimap inherits Rectangle {
    width: 14px;
    background: #15181c;
    border-color: Palette.border;
    border-width: 1px;
    for row[i] in AppState.sbs-rows: Rectangle {
        x: 2px;
        y: (i * 1.0 / max(AppState.sbs-rows.length, 1)) * parent.height;
        width: parent.width - 4px;
        height: max(1.5px,
            parent.height / max(AppState.sbs-rows.length, 1));
        // Color: red if only left changed, green if only right, amber if both.
        background:
              (row.left-kind == 1 && row.right-kind == 1) ? #d0a04a
            :  row.left-kind == 1                         ? #ec7c7c
            :  row.right-kind == 1                        ? #6cd07c
            :                                               transparent;
    }
    Rectangle {
        x: 0;
        y: AppState.sbs-content-height > 0
            ? (-AppState.sbs-viewport-y / AppState.sbs-content-height) * parent.height
            : 0;
        width: parent.width;
        height: AppState.sbs-content-height > 0
            ? max(8px, (AppState.diff-visible-height / AppState.sbs-content-height) * parent.height)
            : 0;
        background: #ffffff20;
        border-color: #ffffff60;
        border-width: 1px;
    }
    TouchArea {
        clicked => {
            AppState.sbs-viewport-y =
                -((self.mouse-y / parent.height) * AppState.sbs-content-height
                  - AppState.diff-visible-height / 2);
        }
    }
}

// GitHub-Dark inspired palette for the diff view.
//   bg-add        — addition row background
//   bg-del        — deletion row background
//   bg-hunk       — hunk-header row background
//   bg-gutter     — line-number gutter background
//   bg-gutter-add — line-number gutter on an addition row
//   bg-gutter-del — line-number gutter on a deletion row
//   fg-add / fg-del — code text color on addition / deletion rows
//   fg-gutter     — line-number text
//   fg-hunk       — hunk-header text (blue)
export struct DiffColors {
    bg-add: color,
    bg-del: color,
    bg-hunk: color,
    bg-gutter: color,
    bg-gutter-add: color,
    bg-gutter-del: color,
    fg-add: color,
    fg-del: color,
    fg-gutter: color,
    fg-hunk: color,
}

global DiffPalette {
    out property <DiffColors> c: {
        bg-add: #033a1622,
        bg-del: #67060c22,
        bg-hunk: #1c2a3a,
        bg-gutter: #161b22,
        bg-gutter-add: #0d4423,
        bg-gutter-del: #4d141a,
        fg-add: #aff5b4,
        fg-del: #ffabb4,
        fg-gutter: #6e7681,
        fg-hunk: #6cb6ff,
    };
}

component DiffPane inherits Rectangle {
    background: Palette.background;
    border-color: Palette.border;
    border-width: 1px;
    VerticalBox {
        padding: 0;
        spacing: 0;
        Rectangle {
            height: 36px;
            background: Palette.alternate-background;
            HorizontalBox {
                padding-left: 10px;
                padding-right: 8px;
                spacing: 8px;
                Text {
                    text: "Diff";
                    vertical-alignment: center;
                    font-weight: 600;
                }
                Rectangle { horizontal-stretch: 1; }
                // Mode toggles with icons.
                Button {
                    icon: @image-url("icons/align-left.svg");
                    text: "Inline";
                    primary: AppState.diff-mode == 0;
                    clicked => { AppState.diff-mode = 0; }
                }
                Button {
                    icon: @image-url("icons/columns-2.svg");
                    text: "Split";
                    primary: AppState.diff-mode == 1;
                    clicked => { AppState.diff-mode = 1; }
                }
                Button {
                    icon: @image-url("icons/list-filter.svg");
                    text: AppState.show-context ? "All" : "Changed";
                    primary: !AppState.show-context;
                    clicked => { AppState.show-context = !AppState.show-context; }
                }
            }
        }
        HorizontalLayout {
            padding: 0;
            spacing: 0;
            Rectangle {
                horizontal-stretch: 1;
                background: Palette.background;
                if AppState.diff-mode == 0: ScrollView {
                    x: 0; y: 0; width: parent.width; height: parent.height;
                    viewport-y <=> AppState.inline-viewport-y;
                    changed visible-height => { AppState.diff-visible-height = self.visible-height; }
                    VerticalBox {
                        padding: 0;
                        spacing: 0;
                        if AppState.diff-segments.length == 0: Text {
                            text: "Select an item on the left to see its diff.";
                            color: Palette.foreground.with-alpha(0.7);
                        }
                        for seg[i] in AppState.diff-segments: Rectangle {
                            height: (seg.kind == 0 && !AppState.show-context) ? 0px : 18px;
                            visible: seg.kind != 0 || AppState.show-context;
                            clip: true;
                            background:
                                seg.kind == 3 ? DiffPalette.c.bg-hunk
                              : seg.kind == 1 ? DiffPalette.c.bg-add
                              : seg.kind == 2 ? DiffPalette.c.bg-del
                              :                 transparent;
                            HorizontalLayout {
                                padding: 0;
                                spacing: 0;
                                // Left gutter — A line number.
                                Rectangle {
                                    width: 44px;
                                    background:
                                        seg.kind == 3 ? DiffPalette.c.bg-hunk
                                      : seg.kind == 2 ? DiffPalette.c.bg-gutter-del
                                      :                 DiffPalette.c.bg-gutter;
                                    Text {
                                        x: 0;
                                        width: parent.width - 6px;
                                        horizontal-alignment: right;
                                        text: seg.line-a > 0 ? "\{seg.line-a}" : "";
                                        font-family: "Consolas";
                                        font-size: 11px;
                                        color: DiffPalette.c.fg-gutter;
                                        vertical-alignment: center;
                                    }
                                }
                                // Right gutter — B line number.
                                Rectangle {
                                    width: 44px;
                                    background:
                                        seg.kind == 3 ? DiffPalette.c.bg-hunk
                                      : seg.kind == 1 ? DiffPalette.c.bg-gutter-add
                                      :                 DiffPalette.c.bg-gutter;
                                    Text {
                                        x: 0;
                                        width: parent.width - 6px;
                                        horizontal-alignment: right;
                                        text: seg.line-b > 0 ? "\{seg.line-b}" : "";
                                        font-family: "Consolas";
                                        font-size: 11px;
                                        color: DiffPalette.c.fg-gutter;
                                        vertical-alignment: center;
                                    }
                                }
                                // Code.
                                Rectangle {
                                    horizontal-stretch: 1;
                                    clip: true;
                                    Text {
                                        x: 6px;
                                        text: seg.kind == 3 ? seg.text
                                            : (seg.kind == 1 ? "+ " : seg.kind == 2 ? "- " : "  ") + seg.text;
                                        font-family: "Consolas";
                                        font-size: 11px;
                                        color: seg.kind == 3 ? DiffPalette.c.fg-hunk
                                            : seg.kind == 1 ? DiffPalette.c.fg-add
                                            : seg.kind == 2 ? DiffPalette.c.fg-del
                                            :                 Palette.foreground;
                                        overflow: clip;
                                        wrap: no-wrap;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }
                if AppState.diff-mode == 1: ScrollView {
                    x: 0; y: 0; width: parent.width; height: parent.height;
                    viewport-y <=> AppState.sbs-viewport-y;
                    changed visible-height => { AppState.diff-visible-height = self.visible-height; }
                    VerticalBox {
                        padding: 0;
                        spacing: 0;
                        if AppState.sbs-rows.length == 0: Text {
                            text: "Select an item on the left to see its diff.";
                            color: Palette.foreground.with-alpha(0.7);
                        }
                        for row[i] in AppState.sbs-rows: Rectangle {
                            height:
                                (row.header-kind == 0
                                 && row.left-kind == 0
                                 && row.right-kind == 0
                                 && !AppState.show-context) ? 0px : 18px;
                            visible:
                                row.header-kind != 0
                                || row.left-kind != 0
                                || row.right-kind != 0
                                || AppState.show-context;
                            clip: true;
                            // Hunk header spans the row.
                            if row.header-kind == 3: Rectangle {
                                background: DiffPalette.c.bg-hunk;
                                Text {
                                    x: 6px;
                                    text: row.header-text;
                                    font-family: "Consolas";
                                    font-size: 11px;
                                    color: DiffPalette.c.fg-hunk;
                                    vertical-alignment: center;
                                }
                            }
                            if row.header-kind == 0: HorizontalLayout {
                                padding: 0;
                                spacing: 0;
                                // Left gutter.
                                Rectangle {
                                    width: 40px;
                                    background:
                                        row.left-kind == 1 ? DiffPalette.c.bg-gutter-del
                                      :                      DiffPalette.c.bg-gutter;
                                    Text {
                                        x: 0;
                                        width: parent.width - 6px;
                                        horizontal-alignment: right;
                                        text: row.line-a > 0 ? "\{row.line-a}" : "";
                                        font-family: "Consolas";
                                        font-size: 11px;
                                        color: DiffPalette.c.fg-gutter;
                                        vertical-alignment: center;
                                    }
                                }
                                // Left code.
                                Rectangle {
                                    horizontal-stretch: 1;
                                    clip: true;
                                    background:
                                        row.left-kind == 2 ? Palette.alternate-background
                                      : row.left-kind == 1 ? DiffPalette.c.bg-del
                                      :                      transparent;
                                    Text {
                                        x: 6px;
                                        text: row.left-text;
                                        font-family: "Consolas";
                                        font-size: 11px;
                                        color: row.left-kind == 1 ? DiffPalette.c.fg-del
                                                                  : Palette.foreground;
                                        overflow: clip;
                                        wrap: no-wrap;
                                        vertical-alignment: center;
                                    }
                                }
                                // Divider.
                                Rectangle { width: 1px; background: Palette.border; }
                                // Right gutter.
                                Rectangle {
                                    width: 40px;
                                    background:
                                        row.right-kind == 1 ? DiffPalette.c.bg-gutter-add
                                      :                       DiffPalette.c.bg-gutter;
                                    Text {
                                        x: 0;
                                        width: parent.width - 6px;
                                        horizontal-alignment: right;
                                        text: row.line-b > 0 ? "\{row.line-b}" : "";
                                        font-family: "Consolas";
                                        font-size: 11px;
                                        color: DiffPalette.c.fg-gutter;
                                        vertical-alignment: center;
                                    }
                                }
                                // Right code.
                                Rectangle {
                                    horizontal-stretch: 1;
                                    clip: true;
                                    background:
                                        row.right-kind == 2 ? Palette.alternate-background
                                      : row.right-kind == 1 ? DiffPalette.c.bg-add
                                      :                       transparent;
                                    Text {
                                        x: 6px;
                                        text: row.right-text;
                                        font-family: "Consolas";
                                        font-size: 11px;
                                        color: row.right-kind == 1 ? DiffPalette.c.fg-add
                                                                   : Palette.foreground;
                                        overflow: clip;
                                        wrap: no-wrap;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }
            }
            if AppState.diff-mode == 0: InlineMinimap {}
            if AppState.diff-mode == 1: SbsMinimap {}
        }
    }
}

component PlanDialog inherits Rectangle {
    background: #000a;
    HorizontalBox {
        Rectangle {
            horizontal-stretch: 1;
        }
        Rectangle {
            background: Palette.background;
            border-color: Palette.border;
            border-width: 1px;
            border-radius: 6px;
            width: 720px;
            max-height: 600px;
            VerticalBox {
                padding: 16px;
                spacing: 10px;
                Text {
                    text: "Confirm remap";
                    font-size: 16px;
                    font-weight: 700;
                }
                Text {
                    text: AppState.plan-summary.device-name + "  (" + AppState.plan-summary.aircraft-count + " aircraft, " + AppState.plan-summary.mutation-count + " mutations)";
                    font-size: 12px;
                    color: Palette.foreground.with-alpha(0.8);
                }
                Text {
                    text: "From: " + AppState.plan-summary.from-guid;
                    font-family: "Consolas";
                    font-size: 11px;
                }
                Text {
                    text: " To:  " + AppState.plan-summary.to-guid;
                    font-family: "Consolas";
                    font-size: 11px;
                }
                Text {
                    text: "Backups will be written to:";
                    font-size: 11px;
                    color: Palette.foreground.with-alpha(0.7);
                }
                Text {
                    text: AppState.plan-summary.backup-dir;
                    font-family: "Consolas";
                    font-size: 10px;
                    color: Palette.foreground.with-alpha(0.8);
                    wrap: word-wrap;
                }
                ScrollView {
                    height: 240px;
                    VerticalBox {
                        spacing: 1px;
                        for line[i] in AppState.plan-summary.lines: Text {
                            text: line;
                            font-family: "Consolas";
                            font-size: 10px;
                        }
                    }
                }
                HorizontalBox {
                    Rectangle { horizontal-stretch: 1; }
                    Button {
                        icon: @image-url("icons/x.svg");
                        text: "Cancel";
                        clicked => { AppState.cancel-apply(); }
                    }
                    Button {
                        icon: @image-url("icons/check.svg");
                        text: AppState.applying ? "Applying..." : "Confirm — apply remap";
                        primary: true;
                        enabled: !AppState.applying && !AppState.dcs-running;
                        clicked => { AppState.confirm-apply(); }
                    }
                }
                if AppState.last-result != "": Text {
                    text: AppState.last-result;
                    color: Palette.foreground.with-alpha(0.85);
                    wrap: word-wrap;
                }
            }
        }
        Rectangle {
            horizontal-stretch: 1;
        }
    }
}

component DetailHeader inherits Rectangle {
    height: 56px;
    background: Palette.alternate-background;
    HorizontalBox {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 8px;
        VerticalBox {
            padding: 0;
            spacing: 2px;
            Text {
                text: AppState.selected-index >= 0
                    ? AppState.conflicts[AppState.selected-index].device-name
                    : "";
                font-weight: 700;
                font-size: 14px;
            }
            Text {
                text: AppState.selected-index >= 0
                    ? AppState.conflicts[AppState.selected-index].aircraft + " / " + AppState.conflicts[AppState.selected-index].subtype
                    : "";
                font-size: 11px;
                color: Palette.foreground.with-alpha(0.7);
            }
        }
        Rectangle { horizontal-stretch: 1; }
        // Two-candidate case: pick which content stays, target is the live one (if any).
        if AppState.selected-index >= 0 && !AppState.conflicts[AppState.selected-index].is-orphan: Button {
            text: "Use A (" + (AppState.conflicts[AppState.selected-index].candidate-a-live ? "live" : "stale") + ")";
            enabled: !AppState.dcs-running && !AppState.applying;
            clicked => {
                // Source = A; target = live one (B if B is live, else A's GUID -> falls back to A no-op which Rust rejects).
                AppState.request-plan(
                    AppState.conflicts[AppState.selected-index].candidate-a-guid,
                    AppState.conflicts[AppState.selected-index].candidate-b-live
                        ? AppState.conflicts[AppState.selected-index].candidate-b-guid
                        : AppState.conflicts[AppState.selected-index].candidate-a-guid
                );
            }
        }
        if AppState.selected-index >= 0 && !AppState.conflicts[AppState.selected-index].is-orphan: Button {
            text: "Use B (" + (AppState.conflicts[AppState.selected-index].candidate-b-live ? "live" : "stale") + ")";
            enabled: !AppState.dcs-running && !AppState.applying;
            clicked => {
                AppState.request-plan(
                    AppState.conflicts[AppState.selected-index].candidate-b-guid,
                    AppState.conflicts[AppState.selected-index].candidate-a-live
                        ? AppState.conflicts[AppState.selected-index].candidate-a-guid
                        : AppState.conflicts[AppState.selected-index].candidate-b-guid
                );
            }
        }
        // Orphan: only one source, target is the live GUID.
        if AppState.selected-index >= 0 && AppState.conflicts[AppState.selected-index].is-orphan: Button {
            text: "Remap to live";
            primary: true;
            enabled: !AppState.dcs-running && !AppState.applying;
            clicked => {
                AppState.request-plan(
                    AppState.conflicts[AppState.selected-index].candidate-a-guid,
                    AppState.conflicts[AppState.selected-index].orphan-target-guid
                );
            }
        }
    }
}

export component App inherits Window {
    title: "DCSBinder";
    preferred-width: 1280px;
    preferred-height: 800px;
    min-width: 800px;
    min-height: 500px;
    background: Palette.background;
    icon: @image-url("");

    VerticalBox {
        padding: 0;
        spacing: 0;
        StatusBar {}
        InstallsPanel {}
        HorizontalBox {
            padding: 0;
            spacing: 0;
            ConflictsList {}
            VerticalBox {
                padding: 0;
                spacing: 0;
                DetailHeader {}
                DiffPane {
                    vertical-stretch: 1;
                }
            }
        }
    }

    if AppState.plan-visible: PlanDialog {
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
    }
}
